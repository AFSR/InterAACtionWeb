{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/",                        "destination": "/portal/index.html" },
    { "source": "/service-worker.js",       "destination": "/portal/service-worker.js" },
    { "source": "/manifest.webmanifest",    "destination": "/portal/manifest.webmanifest" },
    { "source": "/assets/:path*",           "destination": "/portal/assets/:path*" },
    { "source": "/augcom",                  "destination": "/apps/augcom/dist/index.html" },
    { "source": "/augcom/",                 "destination": "/apps/augcom/dist/index.html" },
    { "source": "/augcom/:path*",           "destination": "/apps/augcom/dist/:path*" }
  ],
  "headers": [
    {
      "source": "/service-worker.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Service-Worker-Allowed", "value": "/" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/augcom/(.*)\\.(js|css|png|jpg|svg|woff2?)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
